@startuml diagram
' Configurações visuais para deixar o diagrama mais limpo e profissional
hide circle
skinparam linetype ortho
skinparam shadowing false
skinparam class {
    BackgroundColor White
    ArrowColor #2688d4
    BorderColor #2688d4
}

' --- Definição das Classes (Tabelas + Métodos) ---

class "Usuario" as usuario {
  * id_usuario : int <<PK>>
  --
  nome_completo : String
  matricula : String
  email : String
  senha_hash : String
  curso : String
  preferencias_notificacao : boolean
  modo_escuro : boolean
  ==
  + autenticarUsuario(matricula, senha)
  + logout()
  + visualizarPerfil(idUsuario)
  + atualizarPerfil(idUsuario, novosDados)
  + recuperarSenha(email)
  + alterarSenha(novaSenha)
}

class "Estudante" as estudante {
  --
  ==
  + cadastrarUsuario(dadosUsuario)
  + atualizarPreferencias(dados)
}

class "Administrador" as admin {
  --
  cargo_setor : String
  ==
  + gerenciarSolicitacoes()
  + visualizarRelatorios()
  + gerenciarUsuarios()
}

class "Servico" as servico {
  * id_servico : int <<PK>>
  --
  nome_servico : String
  categoria_servico : Enum ('Impressao', 'Plotagem', 'Digitalizacao', 'Produto')
  preco_unitario : double
  disponivel : boolean
  ==
  + listarServicosAtivos()
  + cadastrarServico(dadosServico)
  + atualizarDisponibilidade(idServico, status)
}

class "Pedido" as pedido {
  * id_pedido : int <<PK>>
  --
  ~ id_usuario : int <<FK>>
  data_hora : Datetime
  status_fila : Enum ('Pendente', 'Na Fila', 'Imprimindo', 'Pronto', 'Cancelado')
  arquivo_url : String
  tamanho_arquivo_mb : double
  total_paginas_arquivo : int
  valor_total : double
  ==
  + criarPedido(idUsuario)
  + adicionarItemAoPedido(idPedido, detalhesItem)
  + fazerUploadArquivo(arquivo)
  + calcularValorTotal(idPedido)
  + confirmarPedido(idPedido)
  + atualizarStatusPedido(idPedido, novoStatus)
  + listarPedidosPorUsuario(idUsuario)
  + listarFilaDePedidos()
  + cancelarPedido(idPedido)
  + obterEstatisticasUsuario(idUsuario)
  + estimarTempoFila(idPedido)
  + obterPosicaoFila(idPedido)
}

class "Item_Pedido" as item_pedido {
  * id_item : int <<PK>>
  --
  ~ id_pedido : int <<FK>>
  ~ id_servico : int <<FK>>
  quantidade : int
  tamanho_papel : String
  orientacao : Enum ('Retrato', 'Paisagem')
  frente_verso : boolean
  tipo_cor : Enum ('Preto e Branco', 'Colorido')
  observacoes : String
  ==
}

class "Pagamento" as pagamento {
  * id_pagamento : int <<PK>>
  --
  ~ id_pedido : int <<FK>>
  metodo : String ('PIX', 'Dinheiro', 'Cartao')
  status_pagamento : Enum ('Pendente', 'Pago')
  ==
  + registrarPagamento(idPedido, metodo)
  + atualizarStatusPagamento(idPagamento, status)
}

class "Notificacao" as notificacao {
  * id_notificacao : int <<PK>>
  --
  ~ id_usuario : int <<FK>>
  titulo : String
  mensagem : String
  lida : boolean
  data_hora : Datetime
  ==
  + listarNotificacoes(idUsuario)
  + marcarComoLida(idNotificacao)
}

class "Configuracao_Sistema" as config {
  * id_config : int <<PK>>
  --
  setor_aberto : boolean
  mensagem_aviso : String
  ==
  + verificarStatusSetor()
  + alterarStatusSetor(status, mensagem)
  + enviarNotificacao(idUsuario, mensagem)
  + obterQuadroHorarios()
}

' --- Definição dos Relacionamentos ---

' Herança: Estudante e Administrador são tipos de Usuário
usuario <|-- estudante
usuario <|-- admin

' Um Usuário pode ter ZERO ou VÁRIOS Pedidos (1:N)
usuario ||--o{ pedido : "realiza"

' Um Usuário pode receber ZERO ou VÁRIAS Notificações (1:N)
usuario ||--o{ notificacao : "recebe"

' Um Pedido deve ter UM ou VÁRIOS Itens (1:N)
pedido ||--|{ item_pedido : "contém"

' Um Serviço pode estar em ZERO ou VÁRIOS Itens de Pedido (1:N)
servico ||--o{ item_pedido : "é adicionado em"

' Um Pedido pode ter ZERO ou UM Pagamento registrado (1:1)
pedido ||--o| pagamento : "possui"

@enduml